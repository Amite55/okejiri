{
  "expo": {
    "name": "Okejiri",
    "slug": "okejiriMobileApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splashSquire.png",
    "scheme": "okejirimobileapp",
    "userInterfaceStyle": "automatic",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "511875f9-9c03-4895-869c-e4670da67d0e"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.okejiri.sm.solutions.app",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/appAndroidIcon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.okejiri.sm.solutions.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/appAndroidIcon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splashSquire.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {}
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "This app requires access to your photos so you can upload a profile picture and share images for your products or services."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Okejiri to access your camera to capture identity documents for KYC verification."
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-google-signin/google-signin",
      "@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "m_amite"
  }
}
